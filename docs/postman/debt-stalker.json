{
  "info": {
    "name": "Debt Stalker \u2014 API",
    "description": "API collection for the ES+MX vertical slice (Phase 1 + health).\n\nSetup:\n1. Run `make up && make setup && make run`\n2. Execute 'Get Token' request first to populate {{token}} variable\n3. All other requests use {{token}} automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:4000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "application_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is ok', function () {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Token (read)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/token",
            "body": {
              "mode": "raw",
              "raw": "{\"role\": \"read\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Token (update)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/token",
            "body": {
              "mode": "raw",
              "raw": "{\"role\": \"update\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Create Application (ES)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/applications",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country\": \"ES\",\n  \"full_name\": \"Juan Garcia Lopez\",\n  \"identity_document\": \"12345678Z\",\n  \"requested_amount\": \"5000\",\n  \"monthly_income\": \"2000\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data) { pm.collectionVariables.set('application_id', jsonData.data.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Application (ES - Over Threshold)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/applications",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country\": \"ES\",\n  \"full_name\": \"Maria Rodriguez\",\n  \"identity_document\": \"87654321X\",\n  \"requested_amount\": \"25000\",\n  \"monthly_income\": \"1500\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.test('additional_review_required is true', function() {",
                  "  pm.expect(jsonData.data.additional_review_required).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Application (MX)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/applications",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country\": \"MX\",\n  \"full_name\": \"Roberto Hernandez\",\n  \"identity_document\": \"GARC850101HDFRRL09\",\n  \"requested_amount\": \"80000\",\n  \"monthly_income\": \"15000\"\n}"
            }
          }
        },
        {
          "name": "List Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/applications?limit=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "applications"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "List Applications (filter by country)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/applications?country=ES",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "applications"
              ],
              "query": [
                {
                  "key": "country",
                  "value": "ES"
                }
              ]
            }
          }
        },
        {
          "name": "Get Application",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/applications/{{application_id}}"
          }
        },
        {
          "name": "Update Status (\u2192 pending_risk)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/applications/{{application_id}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"pending_risk\"}"
            }
          }
        },
        {
          "name": "Update Status (\u2192 approved)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/applications/{{application_id}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"approved\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Provider Webhook (status confirmation)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/webhooks/provider-confirmations",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"application_id\": \"{{application_id}}\",\n  \"status\": \"approved\",\n  \"source\": \"provider_es\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Rate Limiting",
      "description": "Verify 429 rate limit responses and retry hints on auth token and webhook endpoints.",
      "item": [
        {
          "name": "POST /api/auth/token (x100 rapid \u2014 expect 429)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Forwarded-For",
                "value": "203.0.113.50"
              }
            ],
            "url": "{{base_url}}/api/auth/token",
            "body": {
              "mode": "raw",
              "raw": "{\"role\": \"read\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 429) {",
                  "    pm.test('429 returned', function () {",
                  "        pm.response.to.have.status(429);",
                  "    });",
                  "    pm.test('Retry-After header present', function () {",
                  "        pm.response.to.have.header('Retry-After');",
                  "    });",
                  "    pm.test('Error body correct', function () {",
                  "        var body = pm.response.json();",
                  "        pm.expect(body.error).to.eql('rate_limit_exceeded');",
                  "    });",
                  "} else {",
                  "    pm.test('Request allowed (under limit)', function () {",
                  "        pm.response.to.have.status(200).or.status(400);",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/webhooks/provider-confirmations (x100 rapid \u2014 expect 429)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Forwarded-For",
                "value": "203.0.113.51"
              }
            ],
            "url": "{{base_url}}/api/webhooks/provider-confirmations",
            "body": {
              "mode": "raw",
              "raw": "{\"event_id\": \"test-rate-limit\", \"application_id\": \"00000000-0000-0000-0000-000000000000\", \"status\": \"approved\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 429) {",
                  "    pm.test('429 returned', function () {",
                  "        pm.response.to.have.status(429);",
                  "    });",
                  "    pm.test('Retry-After header present', function () {",
                  "        pm.response.to.have.header('Retry-After');",
                  "    });",
                  "    pm.test('Error body correct', function () {",
                  "        var body = pm.response.json();",
                  "        pm.expect(body.error).to.eql('rate_limit_exceeded');",
                  "    });",
                  "} else {",
                  "    pm.test('Request allowed (under limit)', function () {",
                  "        pm.response.to.have.status(200).or.status(401).or.status(422);",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Provider Failures",
      "description": "Phase 2 failure scenarios: provider errors and circuit breaker behavior",
      "item": [
        {
          "name": "Create Application (forced provider error)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{read_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/applications",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "applications"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country\": \"ES\",\n  \"full_name\": \"Test Provider Error\",\n  \"identity_document\": \"99999999R\",\n  \"requested_amount\": \"5000.00\",\n  \"monthly_income\": \"3000.00\"\n}"
            },
            "description": "Create application that will trigger a provider error. When the provider is unavailable or times out, the application transitions to provider_error status. The circuit breaker opens after N consecutive failures."
          },
          "response": [
            {
              "name": "Provider Error Response",
              "status": "201",
              "code": 201,
              "body": "{\n  \"id\": \"uuid-here\",\n  \"status\": \"provider_error\",\n  \"country\": \"ES\",\n  \"identity_document\": \"****9999R\",\n  \"provider_summary\": null,\n  \"additional_review_required\": false\n}"
            }
          ]
        },
        {
          "name": "Get Application (provider_error status)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{read_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/applications/{{application_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "applications",
                "{{application_id}}"
              ]
            },
            "description": "Retrieve an application in provider_error status. The circuit breaker may be open, causing subsequent provider calls to fail fast."
          },
          "response": [
            {
              "name": "Provider Error Status",
              "status": "200",
              "code": 200,
              "body": "{\n  \"id\": \"uuid-here\",\n  \"status\": \"provider_error\",\n  \"country\": \"ES\",\n  \"identity_document\": \"****9999R\",\n  \"provider_summary\": null,\n  \"additional_review_required\": false\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "DLQ Inspection",
      "description": "Phase 2: Dead-letter queue inspection for failed Oban jobs",
      "item": [
        {
          "name": "List Dead-Letter Jobs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/dead-letters",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "dead-letters"
              ]
            },
            "description": "List dead-lettered Oban jobs. Jobs are moved to the DLQ after exhausting retries. Each entry retains original args, error message, and metadata."
          },
          "response": [
            {
              "name": "Dead-Letter List",
              "status": "200",
              "code": 200,
              "body": "{\n  \"dead_letters\": [\n    {\n      \"id\": \"uuid-here\",\n      \"worker\": \"DebtStalker.Workers.RiskEvaluationWorker\",\n      \"args\": {\n        \"application_id\": \"uuid-here\"\n      },\n      \"error\": \"Provider timeout after 5000ms\",\n      \"inserted_at\": \"2026-01-15T10:30:00Z\"\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Replay Dead-Letter Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/dead-letters/{{dead_letter_id}}/replay",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "dead-letters",
                "{{dead_letter_id}}",
                "replay"
              ]
            },
            "description": "Re-enqueue a dead-lettered job for retry. The original args are preserved and a new Oban job is inserted."
          },
          "response": [
            {
              "name": "Replay Success",
              "status": "200",
              "code": 200,
              "body": "{\n  \"status\": \"reenqueued\",\n  \"job_id\": \"new-uuid-here\"\n}"
            }
          ]
        }
      ]
    }
  ]
}