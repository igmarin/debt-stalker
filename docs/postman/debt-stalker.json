{
  "info": {
    "name": "Debt Stalker — API",
    "description": "API collection for the ES+MX vertical slice (Phase 1 + Phase 2).\n\nSetup:\n1. Run `make up && make setup && make run`\n2. Execute 'Get Token (update)' first to populate {{token}}\n3. The Create Application requests capture {{application_id}} automatically\n4. Webhook requests compute HMAC-SHA256 over the raw body using {{webhook_secret}} (default: dev-webhook-secret)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:4000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "application_id",
      "value": ""
    },
    {
      "key": "cursor",
      "value": ""
    },
    {
      "key": "webhook_secret",
      "value": "dev-webhook-secret"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is healthy', function () {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('healthy');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Liveness Probe",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/health/live"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('liveness returns ok', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Readiness Probe",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/health/ready"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('readiness returns ready or not_ready', function () {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.status).to.be.oneOf(['ready', 'not_ready']);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Token (read)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/token",
            "body": {
              "mode": "raw",
              "raw": "{\"role\": \"read\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Token (update)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/token",
            "body": {
              "mode": "raw",
              "raw": "{\"role\": \"update\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Create Application (ES)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/applications",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country\": \"ES\",\n  \"full_name\": \"Juan Garcia Lopez\",\n  \"identity_document\": \"12345678Z\",\n  \"requested_amount\": \"5000\",\n  \"monthly_income\": \"2000\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.id) {",
                  "  pm.collectionVariables.set('application_id', jsonData.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Application (ES - Over Threshold)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/applications",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country\": \"ES\",\n  \"full_name\": \"Maria Rodriguez\",\n  \"identity_document\": \"87654321X\",\n  \"requested_amount\": \"25000\",\n  \"monthly_income\": \"1500\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.test('additional_review_required is true', function() {",
                  "  pm.expect(jsonData.data.additional_review_required).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Application (MX)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/applications",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country\": \"MX\",\n  \"full_name\": \"Roberto Hernandez\",\n  \"identity_document\": \"GARC850101HDFRRL09\",\n  \"requested_amount\": \"80000\",\n  \"monthly_income\": \"15000\"\n}"
            }
          }
        },
        {
          "name": "List Applications (first page)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/applications?limit=5",
              "host": ["{{base_url}}"],
              "path": ["api", "applications"],
              "query": [
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.cursor) {",
                  "  pm.collectionVariables.set('cursor', jsonData.cursor);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List Applications (next page via cursor)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/applications?limit=5&cursor={{cursor}}",
              "host": ["{{base_url}}"],
              "path": ["api", "applications"],
              "query": [
                {
                  "key": "limit",
                  "value": "5"
                },
                {
                  "key": "cursor",
                  "value": "{{cursor}}"
                }
              ]
            }
          }
        },
        {
          "name": "List Applications (filter by country)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/applications?country=ES&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "applications"],
              "query": [
                {
                  "key": "country",
                  "value": "ES"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Application",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/applications/{{application_id}}"
          }
        },
        {
          "name": "Update Status (→ pending_risk)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/applications/{{application_id}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"pending_risk\"}"
            }
          }
        },
        {
          "name": "Update Status (→ additional_review)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/applications/{{application_id}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"additional_review\"}"
            }
          }
        },
        {
          "name": "Update Status (→ approved)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/applications/{{application_id}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"approved\"}"
            }
          }
        },
        {
          "name": "Update Status (→ rejected)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/applications/{{application_id}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"rejected\"}"
            }
          }
        },
        {
          "name": "Update Status (→ cancelled)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/applications/{{application_id}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"cancelled\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Provider Webhook (status confirmation)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-webhook-signature",
                "value": "{{webhook_signature}}"
              }
            ],
            "url": "{{base_url}}/api/webhooks/provider-confirmations",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"application_id\": \"{{application_id}}\",\n  \"status\": \"approved\",\n  \"source\": \"provider_es\"\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var CryptoJS = require('crypto-js');",
                  "var body = pm.request.body.raw;",
                  "var secret = pm.collectionVariables.get('webhook_secret');",
                  "var signature = CryptoJS.HmacSHA256(body, secret).toString(CryptoJS.enc.Hex).toLowerCase();",
                  "pm.collectionVariables.set('webhook_signature', signature);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('webhook accepted', function () {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.received).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Rate Limiting",
      "description": "These requests demonstrate rate limiting. To reliably hit the limit, run the same request rapidly (e.g., via Postman Runner) or lower RATE_LIMIT_AUTH_TOKEN/RATE_LIMIT_WEBHOOK in runtime config.",
      "item": [
        {
          "name": "POST /api/auth/token (rapid — expect 429 eventually)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Forwarded-For",
                "value": "203.0.113.50"
              }
            ],
            "url": "{{base_url}}/api/auth/token",
            "body": {
              "mode": "raw",
              "raw": "{\"role\": \"read\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 429) {",
                  "  pm.test('429 returned', function () {",
                  "    pm.response.to.have.status(429);",
                  "  });",
                  "  pm.test('Retry-After header present', function () {",
                  "    pm.response.to.have.header('Retry-After');",
                  "  });",
                  "  pm.test('Error body correct', function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body.error).to.eql('rate_limit_exceeded');",
                  "  });",
                  "} else {",
                  "  pm.test('Request allowed (under limit)', function () {",
                  "    pm.response.to.have.status(200).or.status(400);",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /api/webhooks/provider-confirmations (rapid — expect 429 eventually)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Forwarded-For",
                "value": "203.0.113.51"
              }
            ],
            "url": "{{base_url}}/api/webhooks/provider-confirmations",
            "body": {
              "mode": "raw",
              "raw": "{\"event_id\": \"test-rate-limit\", \"application_id\": \"00000000-0000-0000-0000-000000000000\", \"status\": \"approved\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 429) {",
                  "  pm.test('429 returned', function () {",
                  "    pm.response.to.have.status(429);",
                  "  });",
                  "  pm.test('Retry-After header present', function () {",
                  "    pm.response.to.have.header('Retry-After');",
                  "  });",
                  "  pm.test('Error body correct', function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body.error).to.eql('rate_limit_exceeded');",
                  "  });",
                  "} else {",
                  "  pm.test('Request allowed (under limit)', function () {",
                  "    pm.response.to.have.status(200).or.status(401).or.status(422);",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Provider Failures",
      "description": "Phase 2 failure scenarios: provider errors and circuit breaker behavior. Use the update token for create operations.",
      "item": [
        {
          "name": "Create Application (forced provider error)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/applications",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country\": \"ES\",\n  \"full_name\": \"Test Provider Error\",\n  \"identity_document\": \"99999999R\",\n  \"requested_amount\": \"5000.00\",\n  \"monthly_income\": \"3000.00\"\n}"
            },
            "description": "Create application that will trigger a provider error. When the provider is unavailable or times out, the application transitions to provider_error status."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.test('application created with provider_error status', function() {",
                  "  pm.expect(jsonData.data.status).to.eql('provider_error');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Application (provider_error status)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": "{{base_url}}/api/applications/{{application_id}}",
            "description": "Retrieve an application in provider_error status."
          }
        }
      ]
    }
  ]
}
